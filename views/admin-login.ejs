<%- include('partials/header') %>

<main class="page-shell auth-shell">
  <section class="section">
    <div class="shell-center">
      <div class="auth-card glass-card reveal admin-login-card">
        <span class="section-eyebrow">Admin</span>
        <h1 class="admin-title" style="margin-top:12px;">Acceso editorial.</h1>
        <p class="muted-copy">Entra al panel para publicar, editar y mantener el blog alineado con el rediseño actual de toda la plataforma.</p>

        <% if (error) { %>
          <div class="tag warning" style="margin-top:16px;"><i class="fas fa-circle-exclamation"></i><%= error %></div>
        <% } %>

        <form method="POST" action="/admin/login" class="editor-layout" style="margin-top:20px;">
          <div class="field">
            <label for="password">Contraseña</label>
            <input id="password" name="password" type="password" class="text-input" placeholder="Ingresa la contraseña de admin" required autofocus>
          </div>
          <button type="submit" class="button button-primary">Entrar al panel</button>
        </form>

        <p class="muted-copy" style="margin-top:18px;"><a href="/">Volver al sitio</a></p>
      </div>
    </div>
  </section>
</main>

<%- include('partials/admin-footer') %>
