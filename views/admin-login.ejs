<%- include('partials/header') %>

<style>
/* ============================================
   ADMIN PANEL — Premium Standalone Styles
   Aligned with carloscervantes.qa brand
   ============================================ */
:root {
  --admin-bg:        #FBFBFD;
  --admin-surface:   #FFFFFF;
  --admin-border:    #E5E7EB;
  --admin-text:      #111111;
  --admin-text-2:    #555555;
  --admin-text-3:    #86868B;
  --admin-accent:    #000000;
  --admin-accent-h:  #333333;
  --admin-accent-bg: rgba(0, 0, 0, 0.05);
  --admin-danger:    #DC2626;
  --admin-danger-bg: #FEF2F2;
  --admin-shadow:    0 2px 12px rgba(0,0,0,0.07);
  --admin-radius:    10px;
  --font:            'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  --font-mono:       'JetBrains Mono', 'SFMono-Regular', Menlo, monospace;
}

body { background: var(--admin-bg); }

/* ---- Page wrapper ---- */
.admin-page {
  min-height: calc(100vh - 80px);
  padding: 2.5rem 0;
  margin-top: 80px;
}

/* ---- Card ---- */
.admin-card {
  background: var(--admin-surface);
  border: 1px solid var(--admin-border);
  border-radius: var(--admin-radius);
  box-shadow: var(--admin-shadow);
}

/* ---- Section header bar ---- */
.admin-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
  flex-wrap: wrap;
  margin-bottom: 1.5rem;
}

.admin-bar-title {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--admin-text);
  letter-spacing: -0.02em;
  margin: 0;
}

.admin-bar-sub {
  font-size: 0.875rem;
  color: var(--admin-text-2);
  margin: 0;
}

/* ---- Buttons ---- */
.ab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.65rem 1.25rem;
  border-radius: 8px;
  font-family: var(--font);
  font-weight: 600;
  font-size: 0.9rem;
  border: 1.5px solid transparent;
  cursor: pointer;
  text-decoration: none;
  transition: all 0.2s;
  white-space: nowrap;
}
.ab-primary {
  background: var(--admin-accent);
  color: #fff;
  box-shadow: 0 4px 12px rgba(37,99,235,0.28);
}
.ab-primary:hover {
  background: var(--admin-accent-h);
  color: #fff;
  transform: translateY(-1px);
  box-shadow: 0 6px 18px rgba(37,99,235,0.3);
}
.ab-secondary {
  background: transparent;
  color: var(--admin-text);
  border-color: var(--admin-border);
}
.ab-secondary:hover {
  border-color: var(--admin-accent);
  color: var(--admin-accent);
  background: var(--admin-accent-bg);
}
.ab-icon {
  width: 34px;
  height: 34px;
  padding: 0;
  border-radius: 7px;
  background: var(--admin-bg);
  color: var(--admin-text-2);
  border: 1px solid var(--admin-border);
}
.ab-icon:hover { background: var(--admin-accent); color: #fff; border-color: var(--admin-accent); }
.ab-danger:hover { background: var(--admin-danger); color: #fff; border-color: var(--admin-danger); }

/* ---- Mono label  ---- */
.a-mono {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--admin-accent);
  font-weight: 600;
  padding: 0.2rem 0.7rem;
  background: var(--admin-accent-bg);
  border: 1px solid rgba(37,99,235,0.15);
  border-radius: 999px;
  display: inline-block;
  margin-bottom: 0.5rem;
}
</style>

<!-- Login Page Content -->
<main class="admin-page">
  <div class="container" style="max-width:520px; margin:0 auto;">
    <div class="admin-card" style="padding: 3rem 2.5rem;">

      <!-- Header -->
      <div style="text-align:center; margin-bottom:2.5rem;">
        <!-- Textual Logo -->
        <a href="/" class="nav-brand" style="display:flex;align-items:center;justify-content:center;gap:0.5rem;text-decoration:none;margin-bottom:1.25rem;">
          <img src="/images/brand-logo.png" alt="CC" style="width:40px;height:40px;object-fit:contain;">
          <span style="font-weight:600;letter-spacing:-0.5px;color:var(--admin-text);">Quality & Performance <span style="color:var(--admin-text-3);font-weight:400;margin:0 0.25rem;">/</span> Admin</span>
        </a>
        <h1 style="font-size:1.75rem;font-weight:700;margin:0.5rem 0 0.5rem;color:var(--admin-text);">Admin Access</h1>
        <p style="color:var(--admin-text-2);margin:0;font-size:0.95rem;">Enter your password to manage the blog</p>
      </div>

      <!-- Error -->
      <% if (error) { %>
        <div style="background:var(--admin-danger-bg);color:var(--admin-danger);border:1px solid rgba(220,38,38,0.2);border-radius:8px;padding:1rem 1.25rem;margin-bottom:1.5rem;display:flex;align-items:center;gap:0.75rem;font-size:0.9rem;">
          <i class="fas fa-exclamation-circle"></i>
          <%= error %>
        </div>
      <% } %>

      <!-- Form -->
      <form method="POST" action="/admin/login">
        <div style="margin-bottom:1.5rem;">
          <label for="password" style="display:block;margin-bottom:0.5rem;font-weight:600;font-size:0.875rem;color:var(--admin-text);">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            autofocus
            placeholder="••••••••••••"
            style="width:100%;padding:0.8rem 1rem;border:1.5px solid var(--admin-border);border-radius:8px;font-size:1rem;font-family:var(--font);background:#fff;color:var(--admin-text);transition:border-color 0.2s;outline:none;"
            onfocus="this.style.borderColor='var(--admin-accent)'"
            onblur="this.style.borderColor='var(--admin-border)'"
          >
        </div>

        <button type="submit" class="ab ab-primary" style="width:100%;padding:0.85rem;">
          <i class="fas fa-sign-in-alt"></i>
          Access Dashboard
        </button>
      </form>

      <p style="text-align:center;margin-top:1.5rem;margin-bottom:0;font-size:0.8rem;color:var(--admin-text-3);">
        <a href="/" style="color:var(--admin-text-3);">← Back to site</a>
      </p>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
