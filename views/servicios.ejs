<script src="/js/diagnostico.js"></script>

<script>
(function() {
  // ── FAQ Accordion ──
  document.querySelectorAll('.svc-faq-q').forEach(btn => {
    btn.addEventListener('click', function() {
      const item = this.closest('.svc-faq-item');
      const answer = item.querySelector('.svc-faq-a');
      const isOpen = this.getAttribute('aria-expanded') === 'true';

      // Close all
      document.querySelectorAll('.svc-faq-item').forEach(i => {
        i.querySelector('.svc-faq-q').setAttribute('aria-expanded', 'false');
        i.querySelector('.svc-faq-a').style.maxHeight = null;
        i.querySelector('.svc-faq-icon').textContent = '+';
      });

      if (!isOpen) {
        this.setAttribute('aria-expanded', 'true');
        answer.style.maxHeight = answer.scrollHeight + 'px';
        this.querySelector('.svc-faq-icon').textContent = '×';
      }
    });
  });
})();
</script>
