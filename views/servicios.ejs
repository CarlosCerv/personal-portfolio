<%- include('partials/header') %>
<link rel="stylesheet" href="/css/diagnostico-wizard.css">

<main class="page-shell">

  <!-- ══ HERO ══ -->
  <section class="svc-hero">
    <div class="section-wrap">
      <div class="svc-hero-inner">
        <span class="s-eyebrow reveal">Consultoría</span>
        <h1 class="svc-hero-title reveal d1">Mejora la calidad de tu<br>software. Sin adivinanzas.</h1>
        <p class="svc-hero-sub reveal d2">QA, automatización y performance para equipos que lanzan con confianza.</p>
        <div class="svc-hero-actions reveal d3">
          <a href="#diagnostico" class="button button-primary">Diagnóstico gratuito</a>
          <a href="/profile" class="button button-outline">Ver mi experiencia</a>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider">

  <!-- ══ PAQUETES ══ -->
  <section class="svc-packages-section">
    <div class="section-wrap">
      <div class="section-header reveal">
        <span class="s-eyebrow">Servicios</span>
        <h2 class="s-title">Elige el paquete<br>que necesita tu equipo.</h2>
        <p class="s-sub">Tres soluciones diseñadas para distintos momentos del ciclo de calidad.</p>
      </div>

      <div class="svc-packages-grid">

        <!-- Paquete 1 -->
        <div class="svc-pkg-card reveal">
          <div class="svc-pkg-top">
            <span class="svc-pkg-eyebrow">Inicio</span>
            <h3 class="svc-pkg-name">Diagnóstico QA</h3>
            <div class="svc-pkg-price">$500 <span>USD</span></div>
            <div class="svc-pkg-duration">· 5 días</div>
          </div>
          <ul class="svc-pkg-list">
            <li><span class="svc-check">✓</span>Auditoría completa del proceso de calidad</li>
            <li><span class="svc-check">✓</span>Matriz de riesgos por módulo</li>
            <li><span class="svc-check">✓</span>Roadmap de mejoras priorizado</li>
            <li><span class="svc-check">✓</span>Sesión de presentación de hallazgos</li>
          </ul>
          <a href="#diagnostico" class="button button-outline svc-pkg-cta">Solicitar →</a>
        </div>

        <!-- Paquete 2 — Featured -->
        <div class="svc-pkg-card svc-pkg-featured reveal d1">
          <div class="svc-pkg-badge">Más solicitado</div>
          <div class="svc-pkg-top">
            <span class="svc-pkg-eyebrow">Core</span>
            <h3 class="svc-pkg-name">Automatización</h3>
            <div class="svc-pkg-price">$2,500 <span>USD</span></div>
            <div class="svc-pkg-duration">· 4–6 semanas</div>
          </div>
          <ul class="svc-pkg-list">
            <li><span class="svc-check">✓</span>Suite E2E completa (Web/Mobile)</li>
            <li><span class="svc-check">✓</span>Integración CI/CD (GitHub Actions / Jenkins)</li>
            <li><span class="svc-check">✓</span>Documentación y guía de mantenimiento</li>
            <li><span class="svc-check">✓</span>2 semanas de soporte post-entrega</li>
          </ul>
          <a href="#diagnostico" class="button button-primary svc-pkg-cta">Solicitar →</a>
        </div>

        <!-- Paquete 3 -->
        <div class="svc-pkg-card reveal d2">
          <div class="svc-pkg-top">
            <span class="svc-pkg-eyebrow">Escala</span>
            <h3 class="svc-pkg-name">Performance Engineering</h3>
            <div class="svc-pkg-price">$1,800 <span>USD</span></div>
            <div class="svc-pkg-duration">· 2–4 semanas</div>
          </div>
          <ul class="svc-pkg-list">
            <li><span class="svc-check">✓</span>Pruebas de carga con JMeter / k6</li>
            <li><span class="svc-check">✓</span>Identificación de cuellos de botella</li>
            <li><span class="svc-check">✓</span>Recomendaciones de arquitectura</li>
            <li><span class="svc-check">✓</span>Reporte ejecutivo con evidencias</li>
          </ul>
          <a href="#diagnostico" class="button button-outline svc-pkg-cta">Solicitar →</a>
        </div>

      </div>
    </div>
  </section>

  <hr class="divider">

  <!-- ══ SOCIAL PROOF ══ -->
  <section class="svc-proof-section">
    <div class="section-wrap">
      <div class="svc-proof-grid reveal">
        <div class="svc-proof-item">
          <span class="svc-proof-num">10M+</span>
          <span class="svc-proof-label">Usuarios impactados</span>
        </div>
        <div class="svc-proof-item">
          <span class="svc-proof-num">60%</span>
          <span class="svc-proof-label">Reducción de regresión</span>
        </div>
        <div class="svc-proof-item">
          <span class="svc-proof-num">99.99%</span>
          <span class="svc-proof-label">Uptime garantizado</span>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider">

  <!-- ══ PROCESO ══ -->
  <section class="svc-process-section">
    <div class="section-wrap">
      <div class="section-header reveal">
        <span class="s-eyebrow">Cómo funciona</span>
        <h2 class="s-title">Un proceso simple,<br>transparente y enfocado.</h2>
      </div>
      <div class="svc-process-flow">
        <div class="svc-process-step reveal">
          <span class="svc-process-num">01</span>
          <div class="svc-process-content">
            <strong>Contacto</strong>
            <p>Recibo tu brief y contexto.</p>
          </div>
        </div>
        <div class="svc-process-arrow">→</div>
        <div class="svc-process-step reveal d1">
          <span class="svc-process-num">02</span>
          <div class="svc-process-content">
            <strong>IA analiza</strong>
            <p>Proceso y detecto vacíos.</p>
          </div>
        </div>
        <div class="svc-process-arrow">→</div>
        <div class="svc-process-step reveal d2">
          <span class="svc-process-num">03</span>
          <div class="svc-process-content">
            <strong>Diagnóstico</strong>
            <p>Riesgos y prioridades.</p>
          </div>
        </div>
        <div class="svc-process-arrow">→</div>
        <div class="svc-process-step reveal">
          <span class="svc-process-num">04</span>
          <div class="svc-process-content">
            <strong>Propuesta</strong>
            <p>Plan, tiempos y entregables.</p>
          </div>
        </div>
        <div class="svc-process-arrow">→</div>
        <div class="svc-process-step reveal d1">
          <span class="svc-process-num">05</span>
          <div class="svc-process-content">
            <strong>Entrega</strong>
            <p>Evidencia y hallazgos.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider">

  <!-- ══ DIAGNÓSTICO WIZARD (MAESTRO VERSION) ══ -->
  <section class="svc-diag-section" id="diagnostico">
    <div class="section-wrap">
      <div class="dw-wrapper">
        
        <!-- Header -->
        <div class="dw-header" id="dwWizardHeader">
          <div class="dw-header-top">
            <div>
              <h2 class="dw-title">Diagnóstico QA gratuito</h2>
              <p class="dw-sub">5 preguntas &middot; resultado en 30 segundos</p>
            </div>
            <div class="dw-badge">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
              🔒 Confidencial
            </div>
          </div>
          <hr class="dw-divider">
          
          <!-- Progress -->
          <div class="dw-progress-area">
            <div class="dw-progress-track">
              <div class="dw-progress-fill" id="dwProgressFill"></div>
            </div>
            <div class="dw-step-info">
              <span class="dw-step-label" id="dwStepLabel">Paso 1 de 5 &middot; Tu aplicación</span>
            </div>
            <div class="dw-dots" id="dwDots">
              <div class="dw-dot active"></div><div class="dw-dot-line"></div>
              <div class="dw-dot"></div><div class="dw-dot-line"></div>
              <div class="dw-dot"></div><div class="dw-dot-line"></div>
              <div class="dw-dot"></div><div class="dw-dot-line"></div>
              <div class="dw-dot"></div>
            </div>
          </div>
        </div>

        <form id="dwForm">
          <!-- PASO 1: Tu aplicación -->
          <div class="dw-step active" id="dwStep0">
            <h3 class="dw-question">¿Qué tipo de producto estás desarrollando?</h3>
            <p class="dw-q-sub">Esto define qué pruebas son más relevantes para ti.</p>
            
            <div class="dw-grid" id="dwAppGrid">
              <div class="dw-card" data-value="Web App">
                <div class="dw-card-emoji">🌐</div>
                <div class="dw-card-label">Web App</div>
                <div class="dw-card-desc">Next.js, React, Vue, Angular</div>
              </div>
              <div class="dw-card" data-value="App iOS">
                <div class="dw-card-emoji">📱</div>
                <div class="dw-card-label">App iOS</div>
                <div class="dw-card-desc">Swift, React Native, Flutter</div>
              </div>
              <div class="dw-card" data-value="App Android">
                <div class="dw-card-emoji">🤖</div>
                <div class="dw-card-label">App Android</div>
                <div class="dw-card-desc">Kotlin, React Native, Flutter</div>
              </div>
              <div class="dw-card" data-value="API / Backend">
                <div class="dw-card-emoji">⚡</div>
                <div class="dw-card-label">API / Backend</div>
                <div class="dw-card-desc">REST, GraphQL, Node, API</div>
              </div>
              <div class="dw-card" data-value="Microservicios">
                <div class="dw-card-emoji">🔗</div>
                <div class="dw-card-label">Microservicios</div>
                <div class="dw-card-desc">Kubernetes, Docker, AWS</div>
              </div>
              <div class="dw-card" data-value="E-commerce">
                <div class="dw-card-emoji">🏪</div>
                <div class="dw-card-label">E-commerce</div>
                <div class="dw-card-desc">Shopify, WooCommerce, custom</div>
              </div>
              <div class="dw-card" data-value="HealthTech">
                <div class="dw-card-emoji">🏥</div>
                <div class="dw-card-label">HealthTech</div>
                <div class="dw-card-desc">Apps médicas, regulado</div>
              </div>
              <div class="dw-card" data-value="FinTech">
                <div class="dw-card-emoji">💳</div>
                <div class="dw-card-label">FinTech</div>
                <div class="dw-card-desc">Pagos, banca, crypto</div>
              </div>
            </div>
            
            <div class="dw-nav">
              <button type="button" class="dw-btn dw-btn-primary" id="step0Next" disabled>Continuar →</button>
            </div>
          </div>

          <!-- PASO 2: Escala -->
          <div class="dw-step" id="dwStep1" hidden>
            <h3 class="dw-question">¿Cuántos usuarios activos tienes ahora?</h3>
            <p class="dw-q-sub">Esto determina el nivel de performance testing necesario.</p>
            
            <div class="dw-pill-grid" id="dwScaleGrid">
              <button type="button" class="dw-pill" data-value="Prototipo / MVP">Prototipo / MVP</button>
              <button type="button" class="dw-pill" data-value="< 1,000">&lt; 1,000</button>
              <button type="button" class="dw-pill" data-value="1K–10K">1K–10K</button>
              <button type="button" class="dw-pill" data-value="10K–100K">10K–100K</button>
              <button type="button" class="dw-pill" data-value="100K–1M">100K–1M</button>
              <button type="button" class="dw-pill" data-value="+1M usuarios">+1M usuarios</button>
            </div>
            
            <div id="dwPicoSection" class="dw-fade-in" hidden>
              <h3 class="dw-question" style="font-size:16px; margin-top:32px;">¿Cuántos usuarios esperas en tu próximo pico de tráfico?</h3>
              <div class="dw-pill-grid" id="dwPicoGrid">
                <button type="button" class="dw-pill" data-value="Mismo nivel">Mismo nivel</button>
                <button type="button" class="dw-pill" data-value="2x actual">2x actual</button>
                <button type="button" class="dw-pill" data-value="5x–10x">5x–10x</button>
                <button type="button" class="dw-pill" data-value="Evento masivo (+100K)">Evento masivo (+100K)</button>
                <button type="button" class="dw-pill" data-value="No lo sé">No lo sé</button>
              </div>
              
              <div class="dw-alert" id="dwPicoAlert" hidden>
                ⚠ Con picos así, las pruebas de carga son críticas. Lo analizaremos.
              </div>
            </div>

            <div class="dw-nav">
              <button type="button" class="dw-btn dw-btn-outline" id="step1Back">← Atrás</button>
              <button type="button" class="dw-btn dw-btn-primary" id="step1Next" disabled>Continuar →</button>
            </div>
          </div>

          <!-- PASO 3: Stack Técnico -->
          <div class="dw-step" id="dwStep2" hidden>
            <h3 class="dw-question">¿Qué tecnologías y herramientas usa tu equipo?</h3>
            <p class="dw-q-sub">No necesitas saberlo todo. Marca lo que reconoces.</p>

            <div class="dw-category">
              <div class="dw-cat-title">Frontend / Mobile</div>
              <div class="dw-chip-grid">
                <button type="button" class="dw-chip" data-category="frontend" data-value="React">React</button>
                <button type="button" class="dw-chip" data-category="frontend" data-value="Vue">Vue</button>
                <button type="button" class="dw-chip" data-category="frontend" data-value="Angular">Angular</button>
                <button type="button" class="dw-chip" data-category="frontend" data-value="Next.js">Next.js</button>
                <button type="button" class="dw-chip" data-category="frontend" data-value="Swift/iOS">Swift/iOS</button>
                <button type="button" class="dw-chip" data-category="frontend" data-value="Kotlin/Android">Kotlin/Android</button>
                <button type="button" class="dw-chip" data-category="frontend" data-value="React Native">React Native</button>
                <button type="button" class="dw-chip" data-category="frontend" data-value="Flutter">Flutter</button>
                <button type="button" class="dw-chip" data-category="frontend" data-value="No sé">No sé</button>
              </div>
            </div>
            
            <div class="dw-category">
              <div class="dw-cat-title">Backend / APIs</div>
              <div class="dw-chip-grid">
                <button type="button" class="dw-chip" data-category="backend" data-value="Node.js">Node.js</button>
                <button type="button" class="dw-chip" data-category="backend" data-value="Python">Python</button>
                <button type="button" class="dw-chip" data-category="backend" data-value="Java">Java</button>
                <button type="button" class="dw-chip" data-category="backend" data-value="Go">Go</button>
                <button type="button" class="dw-chip" data-category="backend" data-value="PHP">PHP</button>
                <button type="button" class="dw-chip" data-category="backend" data-value=".NET">.NET</button>
                <button type="button" class="dw-chip" data-category="backend" data-value="GraphQL">GraphQL</button>
                <button type="button" class="dw-chip" data-category="backend" data-value="No sé">No sé</button>
              </div>
            </div>

            <div class="dw-category">
              <div class="dw-cat-title">CI/CD y Testing Actual</div>
              <div class="dw-chip-grid">
                <button type="button" class="dw-chip" data-category="cicd" data-value="GitHub Actions">GitHub Actions</button>
                <button type="button" class="dw-chip" data-category="cicd" data-value="Jenkins">Jenkins</button>
                <button type="button" class="dw-chip" data-category="cicd" data-value="Playwright">Playwright</button>
                <button type="button" class="dw-chip" data-category="cicd" data-value="Cypress">Cypress</button>
                <button type="button" class="dw-chip" data-category="cicd" data-value="Jest">Jest</button>
                <button type="button" class="dw-chip" data-category="cicd" data-value="Sin CI/CD">Sin CI/CD</button>
                <button type="button" class="dw-chip" data-category="cicd" data-value="Sin pruebas">Sin pruebas automatizadas</button>
                <button type="button" class="dw-chip" data-category="cicd" data-value="No sé">No sé</button>
              </div>
            </div>

            <div class="dw-nav">
              <button type="button" class="dw-btn dw-btn-outline" id="step2Back">← Atrás</button>
              <button type="button" class="dw-btn dw-btn-primary" id="step2Next" disabled>Continuar →</button>
            </div>
          </div>

          <!-- PASO 4: Tu mayor dolor -->
          <div class="dw-step" id="dwStep3" hidden>
            <h3 class="dw-question">¿Cuál es el mayor problema de calidad que enfrenta tu equipo?</h3>
            <p class="dw-q-sub">Sé específico — más detalle = diagnóstico más útil.</p>

            <div class="dw-sintoma-grid" id="dwSintomasGrid">
              <div class="dw-sintoma-card" data-value="🐛 Bugs en producción frecuentes">🐛 Bugs en producción frecuentes</div>
              <div class="dw-sintoma-card" data-value="🐢 Releases lentos por miedo a romper algo">🐢 Releases lentos por miedo a romper algo</div>
              <div class="dw-sintoma-card" data-value="📋 QA manual que no escala">📋 QA manual que no escala</div>
              <div class="dw-sintoma-card" data-value="💥 Caídas bajo alto tráfico">💥 Caídas bajo alto tráfico</div>
              <div class="dw-sintoma-card" data-value="📱 App diferente en iOS vs Android">📱 App se comporta diferente en iOS vs Android</div>
              <div class="dw-sintoma-card" data-value="🔗 APIs de terceros que fallan">🔗 APIs de terceros que fallan</div>
              <div class="dw-sintoma-card" data-value="⏱ Sin tiempo para hacer pruebas">⏱ Sin tiempo para hacer pruebas</div>
              <div class="dw-sintoma-card" data-value="👁 Sin visibilidad de la calidad">👁 Sin visibilidad de la calidad real</div>
            </div>

            <div class="dw-textarea-group">
              <label class="dw-label" for="dwContexto">¿Quieres agregar contexto específico? (opcional)</label>
              <textarea id="dwContexto" class="dw-textarea" maxlength="300" placeholder="Ej: Cada deploy del viernes termina en rollback. El equipo tiene miedo de hacer cambios en el módulo de pagos..."></textarea>
              <span class="dw-counter"><span id="dwContextoCounter">0</span> / 300</span>
            </div>

            <div class="dw-nav">
              <button type="button" class="dw-btn dw-btn-outline" id="step3Back">← Atrás</button>
              <button type="button" class="dw-btn dw-btn-primary" id="step3Next" disabled>Continuar →</button>
            </div>
          </div>

          <!-- PASO 5: Recibir diagnóstico -->
          <div class="dw-step" id="dwStep4" hidden>
            <h3 class="dw-question" style="font-size:28px; text-align:center;">Casi listo. ¿Dónde enviamos tu diagnóstico?</h3>
            <p class="dw-q-sub" style="text-align:center;">Recibirás un PDF profesional con el análisis detallado vía email.</p>

            <div class="dw-input-grid" style="margin-top:40px;">
              <div class="dw-field">
                <input type="text" id="dwNombre" class="dw-input" placeholder=" " required>
                <label class="dw-input-label">Nombre completo</label>
              </div>
              <div class="dw-field">
                <input type="email" id="dwEmail" class="dw-input" placeholder=" " required>
                <label class="dw-input-label">Email profesional</label>
              </div>
              <div class="dw-field">
                <input type="text" id="dwEmpresa" class="dw-input" placeholder=" ">
                <label class="dw-input-label">Empresa (opcional)</label>
              </div>
              <div class="dw-field">
                <select id="dwRol" class="dw-select">
                  <option value="" disabled selected>Selecciona tu rol</option>
                  <option value="CTO">CTO / VP Eng</option>
                  <option value="Tech Lead">Tech Lead / QA Lead</option>
                  <option value="Founder">Founder / CEO</option>
                  <option value="Dev">Developer / QA</option>
                  <option value="Otro">Otro</option>
                </select>
                <label class="dw-input-label" style="top: -6px; font-size: 11px;">Rol</label>
              </div>
            </div>

            <div class="dw-privacy-box">
              <p>🔒 <strong>Confidencialidad Garantizada</strong><br>
              Tus datos van directo a Carlos. No los compartimos. El diagnóstico es generado por IA (Claude 3.5 Sonnet) basado en tus respuestas. No guardamos información sensible.</p>
            </div>

            <label class="dw-check-wrap">
              <input type="checkbox" id="dwAccept" required>
              <span>Acepto recibir el diagnóstico y que Carlos me contacte para seguimiento.</span>
            </label>

            <button type="submit" class="dw-btn dw-btn-primary dw-btn-full" id="dwSubmitBtn" disabled>
              Generar diagnóstico gratuito →
            </button>
            <button type="button" class="dw-btn dw-btn-link" id="step4Back">← Modificar respuestas</button>
          </div>
        </form>

        <!-- PANTALAS DE ESTADO (Success / Processing / Results) -->
        
        <div id="dwSentSuccess" class="dw-state-screen" hidden>
            <!-- Animation here -->
        </div>

        <div id="dwProcessing" class="dw-state-screen" hidden>
          <div class="dw-processing-loader">
            <svg class="dw-ring" viewBox="0 0 80 80">
              <circle class="dw-ring-track" cx="40" cy="40" r="36"></circle>
              <circle class="dw-ring-fill" cx="40" cy="40" r="36"></circle>
            </svg>
            <div class="dw-ring-content">IA</div>
          </div>
          
          <div class="dw-timeline" id="dwTimeline">
            <div class="dw-ti-item"><span class="dw-ti-dot"></span> Analizando tipo de aplicación...</div>
            <div class="dw-ti-item"><span class="dw-ti-dot"></span> Evaluando escala y riesgos...</div>
            <div class="dw-ti-item"><span class="dw-ti-dot"></span> Revisando stack tecnológico...</div>
            <div class="dw-ti-item"><span class="dw-ti-dot"></span> Identificando patrones de riesgo...</div>
            <div class="dw-ti-item"><span class="dw-ti-dot"></span> Generando reporte PDF...</div>
          </div>
          
          <div class="dw-rotator" id="dwRotator">
            <p class="active">Revisando tus síntomas contra 100+ proyectos...</p>
            <p>Calculando nivel de riesgo para tu industria...</p>
            <p>Priorizando recomendaciones por impacto...</p>
          </div>
        </div>

        <div id="dwResults" class="dw-results" hidden>
          <div class="dw-results-header">
            <span class="dw-badge-green">✓ Diagnóstico completado</span>
            <h2 class="dw-res-title">Tu diagnóstico QA, <span id="dwResNombre"></span></h2>
            <p class="dw-res-meta">Generado por IA &middot; Revisado por Carlos Cervantes &middot; <span id="dwResDate"></span></p>
          </div>

          <div class="dw-score-card">
            <div class="dw-score-visual">
                <svg class="dw-score-ring" viewBox="0 0 120 120">
                    <circle cx="60" cy="60" r="54" class="dw-ring-bg"></circle>
                    <circle cx="60" cy="60" r="54" class="dw-ring-progress" id="dwScoreRing"></circle>
                </svg>
