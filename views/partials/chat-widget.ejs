<!-- ══════════════════════════════════════════════
     CHAT WIDGET — Carlos · QA Assistant
═══════════════════════════════════════════════ -->
<div class="cw-root" id="chatWidget" aria-label="Chat con Carlos">

  <!-- Floating button -->
  <button class="cw-trigger" id="cwTrigger" aria-label="Abrir chat" aria-expanded="false">
    <img src="/images/profile.jpg" alt="Carlos" class="cw-trigger-photo">
    <span class="cw-badge" id="cwBadge" aria-label="1 mensaje nuevo">1</span>
  </button>

  <!-- Panel -->
  <div class="cw-panel" id="cwPanel" aria-hidden="true">
    <!-- Header -->
    <div class="cw-header">
      <img src="/images/profile.jpg" alt="Carlos Cervantes" class="cw-header-photo">
      <div class="cw-header-info">
        <span class="cw-header-name">Carlos · QA Assistant</span>
        <span class="cw-header-status"><span class="cw-status-dot"></span>En línea</span>
      </div>
      <button class="cw-close" id="cwClose" aria-label="Cerrar chat">×</button>
    </div>

    <!-- Messages -->
    <div class="cw-messages" id="cwMessages" role="log" aria-live="polite">
      <div class="cw-msg cw-msg-bot">
        <p>¡Hola! Soy el asistente de Carlos. Puedo ayudarte con información sobre <a href="/servicios">servicios</a>, <a href="/profile">experiencia</a> o cómo dar el siguiente paso. ¿En qué te ayudo?</p>
      </div>
    </div>

    <!-- Loading dots -->
    <div class="cw-loading" id="cwLoading" hidden>
      <span></span><span></span><span></span>
    </div>

    <!-- Input -->
    <div class="cw-input-row">
      <textarea
        id="cwInput"
        class="cw-input"
        placeholder="Escribe aquí…"
        rows="1"
        aria-label="Mensaje para el asistente"
      ></textarea>
      <button class="cw-send" id="cwSend" aria-label="Enviar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13M22 2L15 22l-4-9-9-4 20-7z"/></svg>
      </button>
    </div>
    <p class="cw-disclaimer">Respuestas IA · puede cometer errores</p>
  </div>

</div>

<script>
(function() {
  const widget = document.getElementById('chatWidget');
  const trigger = document.getElementById('cwTrigger');
  const panel = document.getElementById('cwPanel');
  const closeBtn = document.getElementById('cwClose');
  const badge = document.getElementById('cwBadge');
  const messagesEl = document.getElementById('cwMessages');
  const input = document.getElementById('cwInput');
  const sendBtn = document.getElementById('cwSend');
  const loadingEl = document.getElementById('cwLoading');

  let isOpen = false;
  let chatHistory = [];
  let isLoading = false;

  function openChat() {
    isOpen = true;
    panel.removeAttribute('aria-hidden');
    trigger.setAttribute('aria-expanded', 'true');
    badge.hidden = true;
    widget.classList.add('cw-open');
    setTimeout(() => input.focus(), 350);
  }

  function closeChat() {
    isOpen = false;
    panel.setAttribute('aria-hidden', 'true');
    trigger.setAttribute('aria-expanded', 'false');
    widget.classList.remove('cw-open');
  }

  trigger.addEventListener('click', () => isOpen ? closeChat() : openChat());
  closeBtn.addEventListener('click', closeChat);

  function appendMessage(role, text) {
    const div = document.createElement('div');
    div.className = `cw-msg cw-msg-${role === 'user' ? 'user' : 'bot'}`;
    // Convert newlines and basic links
    const html = text
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
      .replace(/\n/g, '<br>')
      .replace(/(https?:\/\/[^\s<]+)/g, '<a href="$1" target="_blank" rel="noopener">$1</a>')
      .replace(/\/(servicios|profile|contacto|projects|blog|podcast|hobbies)/g, '<a href="/$1">/$1</a>');
    div.innerHTML = `<p>${html}</p>`;
    messagesEl.appendChild(div);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  async function sendMessage() {
    const text = input.value.trim();
    if (!text || isLoading) return;
    input.value = '';
    input.style.height = 'auto';

    appendMessage('user', text);
    chatHistory.push({ role: 'user', content: text });

    isLoading = true;
    loadingEl.hidden = false;
    sendBtn.disabled = true;
    messagesEl.scrollTop = messagesEl.scrollHeight;

    try {
      const resp = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: chatHistory })
      });
      const data = await resp.json();
      const reply = data.reply || 'No pude generar una respuesta.';
      chatHistory.push({ role: 'assistant', content: reply });
      appendMessage('bot', reply);
    } catch (err) {
      appendMessage('bot', 'Error de conexión. Intenta de nuevo.');
    } finally {
      isLoading = false;
      loadingEl.hidden = true;
      sendBtn.disabled = false;
      input.focus();
    }
  }

  sendBtn.addEventListener('click', sendMessage);
  input.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  // Auto-resize textarea
  input.addEventListener('input', function() {
    this.style.height = 'auto';
    this.style.height = Math.min(this.scrollHeight, 120) + 'px';
  });

  // Entry animation
  setTimeout(() => widget.classList.add('cw-visible'), 1500);
})();
</script>
