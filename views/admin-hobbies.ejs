<%- include('partials/header') %>

<%
  const visibleHobbies = hobbies.filter((hobby) => hobby.visible !== false);
  const hiddenHobbies = hobbies.filter((hobby) => hobby.visible === false);
%>

<main class="page-shell admin-shell">
  <section class="section">
    <div class="admin-workspace reveal">
      <div class="admin-overview-card admin-card">
        <div class="admin-toolbar admin-toolbar-top">
          <div class="admin-intro">
            <span class="section-eyebrow">Panel de intereses</span>
            <h1 class="admin-title">Administra toda la información de intereses desde un solo lugar.</h1>
            <p class="muted-copy">Edita textos largos, metadata visual, recursos y el orden de aparición para que la sección pública se mantenga consistente.</p>
            <div class="admin-switcher">
              <a href="/admin/posts" class="chip">Posts</a>
              <a href="/admin/hobbies" class="chip active">Intereses</a>
            </div>
          </div>
          <div class="toolbar-actions admin-hero-actions">
            <a href="/admin/posts" class="button button-ghost">Ir a posts</a>
            <a href="/admin/hobbies/new" class="button button-primary">Nuevo interés</a>
          </div>
        </div>

        <div class="admin-stats-grid">
          <article class="admin-stat-card">
            <span class="admin-stat-label">Intereses visibles</span>
            <strong><%= visibleHobbies.length %></strong>
            <p>Items que hoy se muestran en la página pública.</p>
          </article>
          <article class="admin-stat-card">
            <span class="admin-stat-label">Ocultos</span>
            <strong><%= hiddenHobbies.length %></strong>
            <p>Registros guardados que no se están mostrando al usuario.</p>
          </article>
          <article class="admin-stat-card">
            <span class="admin-stat-label">Con imagen</span>
            <strong><%= hobbies.filter(hobby => hobby.backgroundImage).length %></strong>
            <p>Tarjetas listas para tener mejor impacto visual.</p>
          </article>
          <article class="admin-stat-card">
            <span class="admin-stat-label">Con recursos</span>
            <strong><%= hobbies.filter(hobby => (hobby.resources || []).length > 0).length %></strong>
            <p>Entradas con referencias y recursos adicionales.</p>
          </article>
        </div>
      </div>

      <div class="admin-collection-grid">
        <% hobbies.forEach((hobby) => { %>
          <article class="admin-post-card admin-card reveal">
            <div class="admin-post-card-top">
              <div class="admin-post-copy">
                <div class="admin-post-meta">
                  <span class="status-chip <%= hobby.visible !== false ? 'success' : '' %>">
                    <%= hobby.visible !== false ? 'Visible' : 'Oculto' %>
                  </span>
                  <span class="admin-meta-slug">/<%= hobby.slug %></span>
                </div>
                <h2><%= hobby.title %></h2>
                <p><%= hobby.subtitle %></p>
              </div>
              <div class="admin-post-date">
                <span class="admin-stat-label">Orden</span>
                <strong><%= hobby.order || 0 %></strong>
              </div>
            </div>

            <div class="admin-post-tags">
              <span class="tag"><i class="<%= hobby.icon %>"></i><%= hobby.title %></span>
              <span class="tag"><%= hobby.level || 'Sin nivel' %></span>
              <span class="tag"><%= hobby.frequency || 'Sin frecuencia' %></span>
              <span class="tag <%= hobby.source === 'database' ? 'success' : 'warning' %>"><%= hobby.source === 'database' ? 'Editable en BD' : 'Base inicial' %></span>
            </div>

            <div class="admin-post-actions">
              <a href="/hobbies/<%= hobby.slug %>" target="_blank" rel="noreferrer" class="button button-ghost">Ver público</a>
              <a href="/admin/hobbies/edit/<%= hobby.slug %>" class="button button-ghost">Editar</a>
              <% if (hobby.source === 'database') { %>
                <button type="button" class="button button-dark" onclick="deleteHobby('<%= hobby.slug %>')">Eliminar BD</button>
              <% } %>
            </div>
          </article>
        <% }) %>
      </div>
    </div>
  </section>
</main>

<script>
  async function deleteHobby(slug) {
    if (!confirm('Se eliminará solo la versión guardada en base de datos. ¿Quieres continuar?')) return;

    try {
      const response = await fetch(`/api/admin/hobbies/${slug}`, { method: 'DELETE' });
      const data = await response.json();
      if (data.success) {
        window.location.reload();
        return;
      }
      alert(data.message || 'No fue posible eliminar el interés.');
    } catch (error) {
      alert('Error al eliminar el interés.');
      console.error(error);
    }
  }
</script>

<%- include('partials/footer') %>
