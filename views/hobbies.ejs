<%- include('partials/header') %>

<main class="main-content">
  
  <!-- Unified Header -->
  <section class="content-page-hero">
    <div class="container">
      <div class="hero-badge">
        <i class="fas fa-heart"></i>
        <span>Personal Interests</span>
      </div>
      <h1 class="hero-title-large">Beyond the Console</h1>
      <p class="hero-subtitle-refined">
        Exploring life through photography, fitness, and creativity when I'm not optimizing high-scale systems.
      </p>
    </div>
  </section>

  <!-- Hobbies Grid -->
  <section class="hobbies-section">
    <div class="container">
      <div class="content-grid">
        
        <a href="/hobbies/photography" class="unified-card">
          <div class="card-icon-container"><i class="fas fa-camera"></i></div>
          <div class="card-tag-wrapper"><span class="card-tag">Art</span></div>
          <h3 class="card-title-refined">Photography</h3>
          <p class="card-desc-refined">Capturing high-contrast moments and urban stories through the lens. Specializing in landscape and street photography.</p>
          <div class="card-action-refined">Explore Passion <i class="fas fa-arrow-right"></i></div>
        </a>

        <a href="/hobbies/gym" class="unified-card">
          <div class="card-icon-container"><i class="fas fa-dumbbell"></i></div>
          <div class="card-tag-wrapper"><span class="card-tag">Performance</span></div>
          <h3 class="card-title-refined">Gym & Fitness</h3>
          <p class="card-desc-refined">Maintaining peak physical and mental performance through disciplined training and strength engineering.</p>
          <div class="card-action-refined">Explore Passion <i class="fas fa-arrow-right"></i></div>
        </a>

        <a href="/hobbies/cooking" class="unified-card">
          <div class="card-icon-container"><i class="fas fa-utensils"></i></div>
          <div class="card-tag-wrapper"><span class="card-tag">Creative</span></div>
          <h3 class="card-title-refined">Cooking</h3>
          <p class="card-desc-refined">Experimenting with flavors and techniques. From complex Italian pasta to geometric Asian plating.</p>
          <div class="card-action-refined">Explore Passion <i class="fas fa-arrow-right"></i></div>
        </a>

        <a href="/hobbies/reading" class="unified-card">
          <div class="card-icon-container"><i class="fas fa-book"></i></div>
          <div class="card-tag-wrapper"><span class="card-tag">Knowledge</span></div>
          <h3 class="card-title-refined">Reading</h3>
          <p class="card-desc-refined">Exploring new worlds and expanding perspectives through science fiction, biographies, and technical literature.</p>
          <div class="card-action-refined">Explore Passion <i class="fas fa-arrow-right"></i></div>
        </a>

        <a href="/hobbies/music" class="unified-card">
          <div class="card-icon-container"><i class="fas fa-music"></i></div>
          <div class="card-tag-wrapper"><span class="card-tag">Inspiration</span></div>
          <h3 class="card-title-refined">Music</h3>
          <p class="card-desc-refined">Finding rhythm and harmony as a constant companion for inspiration during deep work and travel.</p>
          <div class="card-action-refined">Explore Passion <i class="fas fa-arrow-right"></i></div>
        </a>

        <a href="/hobbies/travel" class="unified-card">
          <div class="card-icon-container"><i class="fas fa-plane"></i></div>
          <div class="card-tag-wrapper"><span class="card-tag">Adventure</span></div>
          <h3 class="card-title-refined">Travel</h3>
          <p class="card-desc-refined">Exploring diverse cultures and broadening worldviews through international and local exploration.</p>
          <div class="card-action-refined">Explore Passion <i class="fas fa-arrow-right"></i></div>
        </a>

      </div>
    </div>
  </section>

</main>

<%- include('partials/footer') %>
