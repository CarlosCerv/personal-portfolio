<%- include('partials/header') %>

<main class="page-shell">
  <section class="section page-hero hobbies-hero">
    <div class="hobbies-hero-grid">
      <div class="page-hero-copy reveal">
        <span class="section-eyebrow">Intereses</span>
        <h1 class="page-title">La disciplina profesional también se alimenta fuera del teclado.</h1>
        <p class="page-intro">Fotografía, música, viajes, fitness, cocina y lectura forman una parte real de mi manera de pensar, aprender y mantener energía creativa a largo plazo.</p>
        <div class="hero-actions compact">
          <a href="#hobbies-grid" class="button button-primary">Explorar intereses</a>
          <a href="/profile" class="button button-ghost">Ver perfil</a>
        </div>
      </div>

      <div class="hobbies-hero-panel glass-card reveal d1">
        <span class="tag">Balance personal</span>
        <h3>Intereses que fortalecen enfoque, curiosidad y constancia.</h3>
        <div class="hobby-pillars">
          <div class="hobby-pillar">
            <strong>Creatividad</strong>
            <p>Fotografía, música y cocina como espacios para experimentar.</p>
          </div>
          <div class="hobby-pillar">
            <strong>Rendimiento</strong>
            <p>Fitness y hábitos que sostienen claridad mental y energía.</p>
          </div>
          <div class="hobby-pillar">
            <strong>Perspectiva</strong>
            <p>Lectura y viajes para ampliar criterio, contexto y sensibilidad.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section hobbies-overview">
    <div class="section-wrap">
      <div class="section-header reveal">
        <span class="section-eyebrow">Panorama</span>
        <h2 class="section-title">Cada interés suma algo distinto a mi forma de trabajar y vivir.</h2>
        <p class="s-sub">Más que hobbies aislados, son prácticas que aportan estructura, observación, paciencia y curiosidad a mi día a día.</p>
      </div>

      <div class="hobbies-summary-grid">
        <article class="content-card reveal">
          <span class="tag success">Constancia</span>
          <h3>Hábitos sostenibles</h3>
          <p class="muted-copy">La consistencia que exige entrenar, leer o mejorar una técnica se parece mucho a la disciplina necesaria para construir calidad en software.</p>
        </article>
        <article class="content-card reveal d1">
          <span class="tag">Observación</span>
          <h3>Atención al detalle</h3>
          <p class="muted-copy">La fotografía y la música refinan la capacidad de notar patrones, matices y pequeñas señales que normalmente pasan desapercibidas.</p>
        </article>
        <article class="content-card reveal d2">
          <span class="tag warning">Energía</span>
          <h3>Recuperación y enfoque</h3>
          <p class="muted-copy">Mantener hobbies fuera del trabajo ayuda a sostener creatividad, perspectiva y mejor toma de decisiones a largo plazo.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-wrap">
      <div class="section-header reveal">
        <span class="section-eyebrow">Colección</span>
        <h2 class="section-title">Un mapa personal de lo que me inspira fuera del trabajo.</h2>
      </div>

      <div class="hobbies-grid-refined" id="hobbies-grid">
        <% hobbyCards.forEach((hobby, index) => { %>
          <a href="/hobbies/<%= hobby.slug %>" class="hobby-spotlight-card reveal <%= index % 3 === 1 ? 'd1' : index % 3 === 2 ? 'd2' : '' %>">
            <div class="hobby-spotlight-media" style="background-image:linear-gradient(180deg, rgba(255,255,255,0.06), rgba(15,23,42,0.22)), url('<%= hobby.backgroundImage %>');">
              <span class="tag"><i class="<%= hobby.icon %>"></i><%= hobby.title %></span>
            </div>
            <div class="hobby-spotlight-body">
              <h3><%= hobby.title %></h3>
              <p class="muted-copy"><%= hobby.subtitle %></p>
              <div class="hobby-spotlight-meta">
                <span>Desde <%= hobby.started %></span>
                <span><%= hobby.frequency %></span>
                <span><%= hobby.level %></span>
              </div>
              <p class="hobby-spotlight-excerpt"><%= hobby.description %></p>
              <span class="project-link">Ver detalle →</span>
            </div>
          </a>
        <% }) %>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
