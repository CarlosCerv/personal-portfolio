<%- include('partials/header') %>

<main class="page-shell admin-shell">
  <section class="section">
    <div class="admin-editor-workspace reveal">
      <div class="admin-card admin-editor-hero">
        <div class="admin-toolbar admin-toolbar-top">
          <div class="admin-intro">
            <span class="section-eyebrow">Editor editorial</span>
            <h1 class="admin-title"><%= post ? 'Refina el artículo antes de publicarlo.' : 'Crea un nuevo post con mejor estructura.' %></h1>
            <p class="muted-copy">Completa la información base, revisa metadata y redacta el contenido en Markdown con una vista previa integrada.</p>
            <div class="admin-switcher">
              <a href="/admin/posts" class="chip active">Posts</a>
              <a href="/admin/hobbies" class="chip">Intereses</a>
            </div>
          </div>
          <div class="toolbar-actions admin-hero-actions">
            <span class="save-indicator" id="saveIndicator"><i class="fas fa-circle-notch fa-spin"></i>Guardando</span>
            <a href="/admin/posts" class="button button-ghost">Volver al panel</a>
            <button type="button" onclick="togglePreview()" class="button button-ghost" id="previewBtn">Mostrar preview</button>
            <button type="button" onclick="savePost()" class="button button-primary"><%= post ? 'Guardar cambios' : 'Publicar post' %></button>
          </div>
        </div>

        <div class="admin-editor-grid">
          <aside class="admin-editor-sidebar content-card">
            <div class="admin-sidebar-section">
              <span class="admin-sidebar-label">Checklist editorial</span>
              <ul class="bullet-list admin-checklist">
                <li>Título claro y orientado al tema principal.</li>
                <li>Slug limpio y fácil de compartir.</li>
                <li>Meta descripción corta para redes y previews.</li>
                <li>Tags consistentes con la navegación del blog.</li>
              </ul>
            </div>

            <div class="admin-sidebar-section admin-mini-metrics">
              <article class="admin-mini-metric">
                <span>Modo</span>
                <strong><%= post ? 'Edición' : 'Nuevo post' %></strong>
              </article>
              <article class="admin-mini-metric">
                <span>Autor</span>
                <strong><%= post && post.author ? post.author : 'Carlos Cervantes' %></strong>
              </article>
            </div>

            <div class="admin-sidebar-section">
              <label for="metaDescription" class="admin-sidebar-label">Meta descripción</label>
              <textarea id="metaDescription" class="text-area-input text-area-compact" placeholder="Resumen corto para WhatsApp, buscadores y tarjetas sociales"><%= post ? post.metaDescription || '' : '' %></textarea>
            </div>

            <div class="admin-sidebar-section">
              <label for="coverImage" class="admin-sidebar-label">Imagen de portada</label>
              <input id="coverImage" class="text-input" type="text" value="<%= post ? post.coverImage || '' : '' %>" placeholder="/images/og-image.png">
            </div>
          </aside>

          <div class="admin-editor-main">
            <div class="content-card admin-form-card">
              <div class="form-grid">
                <div class="field">
                  <label for="title">Título</label>
                  <input id="title" class="text-input" type="text" value="<%= post ? post.title : '' %>" placeholder="Título del artículo" required>
                </div>
                <div class="field">
                  <label for="slug">Slug</label>
                  <input id="slug" class="text-input" type="text" value="<%= post ? post.slug : '' %>" placeholder="slug-del-articulo" required>
                </div>
              </div>

              <div class="form-grid three" style="margin-top:16px;">
                <div class="field">
                  <label for="author">Autor</label>
                  <input id="author" class="text-input" type="text" value="<%= post && post.author ? post.author : 'Carlos Cervantes' %>" placeholder="Autor">
                </div>
                <div class="field">
                  <label for="date">Fecha</label>
                  <input id="date" class="text-input" type="date" value="<%= post && post.date ? new Date(post.date).toISOString().split('T')[0] : new Date().toISOString().split('T')[0] %>">
                </div>
                <div class="field">
                  <label for="tags">Tags</label>
                  <input id="tags" class="text-input" type="text" value="<%= post && post.tags ? post.tags.join(', ') : '' %>" placeholder="QA, Automatización, Performance">
                </div>
              </div>
            </div>

            <div class="editor-split admin-editor-split" id="editorSplit">
              <div class="editor-panel admin-editor-panel">
                <div class="admin-editor-panel-head">
                  <span class="admin-sidebar-label">Markdown</span>
                  <span class="admin-editor-shortcut">Cmd/Ctrl + S</span>
                </div>
                <textarea id="content" placeholder="Escribe tu artículo en Markdown"><%= post && post.content ? post.content.trim() : '' %></textarea>
              </div>
              <div class="editor-panel preview-panel admin-preview-panel" id="previewPanel">
                <div class="admin-editor-panel-head">
                  <span class="admin-sidebar-label">Vista previa</span>
                  <span class="admin-editor-shortcut">Cmd/Ctrl + P</span>
                </div>
                <div class="admin-preview-body" id="previewBody">
                  <p class="muted-copy">La vista previa aparecerá aquí.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script>
  const ORIGINAL_SLUG = '<%= post ? post.slug : "" %>';

  const titleInput = document.getElementById('title');
  const slugInput = document.getElementById('slug');
  const contentInput = document.getElementById('content');
  const previewBody = document.getElementById('previewBody');

  titleInput.addEventListener('input', function (event) {
    if (!ORIGINAL_SLUG) {
      slugInput.value = event.target.value
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '');
    }
  });

  let previewTimeout;
  contentInput.addEventListener('input', () => {
    clearTimeout(previewTimeout);
    previewTimeout = setTimeout(updatePreview, 250);
  });

  function updatePreview() {
    const content = contentInput.value;
    previewBody.innerHTML = content.trim()
      ? marked.parse(content)
      : '<p class="muted-copy">La vista previa aparecerá aquí.</p>';
  }

  function togglePreview() {
    const split = document.getElementById('editorSplit');
    const panel = document.getElementById('previewPanel');
    const button = document.getElementById('previewBtn');
    const active = panel.classList.toggle('active');
    split.classList.toggle('active', active);
    button.textContent = active ? 'Ocultar preview' : 'Mostrar preview';
    if (active) updatePreview();
  }

  async function savePost() {
    const title = titleInput.value.trim();
    const slug = slugInput.value.trim();
    const content = contentInput.value.trim();

    if (!title || !slug || !content) {
      alert('Completa título, slug y contenido.');
      return;
    }

    if (!/^[a-z0-9-]+$/.test(slug)) {
      alert('El slug solo puede contener minúsculas, números y guiones.');
      return;
    }

    const indicator = document.getElementById('saveIndicator');
    indicator.classList.add('visible');

    try {
      const response = await fetch('/admin/posts/save', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          title,
          slug,
          content,
          originalSlug: ORIGINAL_SLUG,
          date: document.getElementById('date').value,
          author: document.getElementById('author').value.trim(),
          tags: document.getElementById('tags').value.trim(),
          metaDescription: document.getElementById('metaDescription').value.trim(),
          coverImage: document.getElementById('coverImage').value.trim()
        })
      });

      const result = await response.json();
      if (response.ok && result.success) {
        window.location.href = '/admin/posts';
        return;
      }
      alert(result.error || 'Error desconocido al guardar.');
    } catch (error) {
      alert(error.message);
    } finally {
      indicator.classList.remove('visible');
    }
  }

  document.addEventListener('keydown', (event) => {
    if ((event.ctrlKey || event.metaKey) && event.key === 's') {
      event.preventDefault();
      savePost();
    }
    if ((event.ctrlKey || event.metaKey) && event.key === 'p') {
      event.preventDefault();
      togglePreview();
    }
  });

  <% if (post && post.content) { %>
    updatePreview();
  <% } %>
</script>

<%- include('partials/footer') %>
