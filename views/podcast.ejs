<%- include('partials/header') %>

<main class="main-content">
  
  <!-- Unified Header -->
  <section class="content-page-hero">
    <div class="container">
      <div class="hero-badge">
        <i class="fas fa-microphone-alt"></i>
        <span>Audio Insights</span>
      </div>
      <h1 class="hero-title-large">QA Insights Podcast</h1>
      <p class="hero-subtitle-refined">
        Weekly deep dives into Quality Assurance, Test Automation, and Strategic Career Growth with industry leaders.
      </p>
    </div>
  </section>

  <!-- Podcast Content -->
  <section class="podcast-section">
    <div class="container">
      
      <!-- Featured Player -->
      <div class="unified-card featured-player-card" style="margin-bottom: var(--space-12);">
        <div class="card-tag-wrapper">
          <span class="card-tag">Latest Episode</span>
        </div>
        <iframe 
          style="border-radius:16px" 
          src="https://open.spotify.com/embed/show/YOUR_SHOW_ID?utm_source=generator&theme=0" 
          width="100%" 
          height="152" 
          frameBorder="0" 
          allowfullscreen="" 
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" 
          loading="lazy">
        </iframe>
      </div>

      <!-- Episodes Grid -->
      <div class="content-grid">
        <div class="unified-card">
          <div class="card-icon-container"><i class="fas fa-play"></i></div>
          <div class="card-tag-wrapper"><span class="card-tag">Mobile</span></div>
          <h3 class="card-title-refined">Appium vs Espresso: The Final Verdict</h3>
          <p class="card-desc-refined">Deep dive into mobile testing frameworks, comparing cross-platform and native solutions for iOS and Android automation.</p>
          <div class="card-action-refined">Listen to Episode <i class="fas fa-arrow-right"></i></div>
        </div>

        <div class="unified-card">
          <div class="card-icon-container"><i class="fas fa-play"></i></div>
          <div class="card-tag-wrapper"><span class="card-tag">CI/CD</span></div>
          <h3 class="card-title-refined">CI/CD Pipelines for QA Teams</h3>
          <p class="card-desc-refined">Best practices for integrating automated testing into CI/CD pipelines with GitHub Actions and Jenkins.</p>
          <div class="card-action-refined">Listen to Episode <i class="fas fa-arrow-right"></i></div>
        </div>

        <div class="unified-card">
          <div class="card-icon-container"><i class="fas fa-play"></i></div>
          <div class="card-tag-wrapper"><span class="card-tag">Leadership</span></div>
          <h3 class="card-title-refined">From Manual Testing to Leadership</h3>
          <p class="card-desc-refined">Career progression stories and insights on transitioning from hands-on testing to leading QA teams and strategy.</p>
          <div class="card-action-refined">Listen to Episode <i class="fas fa-arrow-right"></i></div>
        </div>
      </div>

    </div>
  </section>

</main>

<%- include('partials/footer') %>
