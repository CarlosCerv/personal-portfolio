<%- include('partials/header') %>
<%
  const allTags = [...new Set(posts.flatMap(post => post.tags || []))].filter(Boolean).sort((a, b) => a.localeCompare(b, 'es')).slice(0, 8);
  const featuredPost = posts[0];
  const remainingPosts = posts.slice(1);
%>

<main class="page-shell">
  <section class="blog-section">
    <div class="section-wrap">
      <div class="section-header reveal">
        <span class="s-eyebrow">Centro de conocimiento</span>
        <h1 class="s-title">Ideas y perspectivas.</h1>
        <p class="s-sub">Perspectivas sobre calidad de software, performance, automatización y arquitectura, con una presentación más editorial, clara y profesional.</p>
      </div>

      <div class="blog-shell">
        <div class="blog-toolbar reveal">
          <div class="blog-filter-panel">
            <div class="search-shell search-shell-blog">
              <span class="blog-search-icon" aria-hidden="true">⌕</span>
              <input id="blogSearch" class="search-input blog-search-input" type="text" placeholder="Buscar por tema, extracto o tag">
              <button type="button" class="blog-clear-button" data-blog-clear hidden>Limpiar</button>
            </div>
            <div class="blog-filter-row">
              <div class="filter-bar filter-bar-blog" role="tablist" aria-label="Filtrar posts por tag">
                <button type="button" class="blog-filter-chip active" data-blog-filter="all">Todos</button>
                <% allTags.forEach(tag => { %>
                  <button type="button" class="blog-filter-chip" data-blog-filter="<%= tag %>"><%= tag %></button>
                <% }); %>
              </div>
              <div class="blog-filter-status" data-blog-results>
                Mostrando <strong><%= posts.length %></strong> artículos
              </div>
            </div>
          </div>
        </div>

        <% if (featuredPost) { %>
          <a
            href="/blog/<%= featuredPost.slug %>"
            class="blog-featured reveal"
            data-post-card
            data-title="<%= featuredPost.title %>"
            data-excerpt="<%= featuredPost.excerpt %>"
            data-tags="<%= (featuredPost.tags || []).join(',') %>"
          >
            <div class="blog-featured-copy">
              <span class="blog-featured-label">Artículo destacado</span>
              <div class="blog-tags blog-tags-featured">
                <% (featuredPost.tags || []).slice(0, 4).forEach(tag => { %>
                  <span class="blog-tag"><%= tag %></span>
                <% }) %>
              </div>
              <h2><%= featuredPost.title %></h2>
              <p><%= featuredPost.excerpt %></p>
              <div class="blog-meta">
                <img src="/images/profile.jpg" alt="<%= featuredPost.author %>">
                <span><%= featuredPost.author %></span>
                <span>·</span>
                <time><%= new Date(featuredPost.date).toLocaleDateString('es-MX', { month: 'short', day: 'numeric', year: 'numeric' }) %></time>
                <span class="blog-stats">
                  <span>·</span>
                  <span><%= featuredPost.likes ? featuredPost.likes.length : 0 %> me gusta</span>
                  <span>·</span>
                  <span><%= featuredPost.commentCount || 0 %> comentarios</span>
                </span>
              </div>
            </div>
            <div class="blog-featured-side">
              <span class="blog-featured-kicker">Lectura recomendada</span>
              <div class="blog-featured-panel">
                <strong>QA, performance y automatización</strong>
                <span>Contenido pensado para líderes técnicos, equipos de calidad y profesionales que están construyendo sistemas más confiables.</span>
              </div>
              <span class="project-link">Leer artículo →</span>
            </div>
          </a>
        <% } %>

        <div class="blog-grid-refined">
      <% remainingPosts.forEach((post, index) => { %>
        <a
          href="/blog/<%= post.slug %>"
          class="blog-card reveal"
          data-post-card
          data-title="<%= post.title %>"
          data-excerpt="<%= post.excerpt %>"
          data-tags="<%= (post.tags || []).join(',') %>"
          style="transition-delay:<%= index * 40 %>ms;"
        >
          <div class="blog-tags">
            <% (post.tags || []).slice(0, 3).forEach(tag => { %>
              <span class="blog-tag"><%= tag %></span>
            <% }) %>
            <% if ((post.tags || []).length > 3) { %>
              <span class="blog-tag blog-tag-muted">+<%= post.tags.length - 3 %></span>
            <% } %>
          </div>
          <div class="blog-title"><%= post.title %></div>
          <p class="blog-excerpt"><%= post.excerpt %></p>
          <div class="blog-meta">
            <img src="/images/profile.jpg" alt="<%= post.author %>">
            <span><%= post.author %></span>
            <span>·</span>
            <time><%= new Date(post.date).toLocaleDateString('es-MX', { month: 'short', day: 'numeric', year: 'numeric' }) %></time>
            <span class="blog-stats">
              <span>·</span>
              <span><%= post.likes ? post.likes.length : 0 %> me gusta</span>
              <span>·</span>
              <span><%= post.commentCount || 0 %> comentarios</span>
            </span>
          </div>
        </a>
      <% }) %>
        </div>
        <div class="blog-empty-state empty-state-card" data-blog-empty hidden>
          <span class="tag">Sin resultados</span>
          <h3>No encontramos artículos con esos filtros.</h3>
          <p class="muted-copy">Prueba con otra palabra clave o limpia el filtro activo para volver a ver todo el contenido.</p>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
