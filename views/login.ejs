<%- include('partials/header') %>

<main class="page-shell auth-shell">
  <section class="section">
    <div class="shell-center">
      <div class="auth-card glass-card reveal">
        <span class="section-eyebrow">Acceso</span>
        <h1 class="auth-title">Bienvenido de nuevo.</h1>
        <p class="muted-copy">Accede a tus interacciones, comentarios y al nuevo panel personal dentro de la plataforma.</p>

        <% if (error) { %>
          <div class="auth-feedback auth-feedback-error"><i class="fas fa-circle-exclamation"></i><span><%= error %></span></div>
        <% } %>

        <form action="/login" method="POST" class="editor-layout auth-form">
          <div class="field">
            <label for="email">Correo</label>
            <input id="email" name="email" type="email" class="text-input" placeholder="you@example.com" value="<%= formData?.email || '' %>" required>
          </div>
          <div class="field">
            <label for="password">Contraseña</label>
            <input id="password" name="password" type="password" class="text-input" placeholder="••••••••" required>
          </div>
          <div class="auth-actions">
            <button type="submit" class="button button-primary">Iniciar sesión</button>
            <a href="/register" class="button button-ghost">Crear cuenta</a>
          </div>
        </form>

        <p class="muted-copy auth-footnote">¿Necesitas una cuenta? <a href="/register">Créala aquí</a>.</p>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
