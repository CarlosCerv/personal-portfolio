<%- include('partials/header') %>

<main class="page-shell">
  <section class="profile-section" id="profile">
    <div class="section-wrap">
      <div class="profile-inner">
        <div class="profile-photo-wrap reveal">
          <div class="profile-photo">
            <img src="/images/profile.jpg" alt="Carlos Cervantes">
          </div>
          <div class="profile-stats-grid">
            <div class="pstat"><div class="pstat-n">50M+</div><div class="pstat-l">Usuarios impactados</div></div>
            <div class="pstat"><div class="pstat-n">100+</div><div class="pstat-l">Proyectos</div></div>
            <div class="pstat"><div class="pstat-n">5K+</div><div class="pstat-l">Bugs resueltos</div></div>
            <div class="pstat"><div class="pstat-n">10K+</div><div class="pstat-l">Test cases</div></div>
          </div>
        </div>
        <div class="profile-content">
          <span class="s-eyebrow reveal" style="text-align:left;display:block;">Perfil</span>
          <h2 class="profile-title reveal d1">Hola, soy Carlos<br>Cervantes.</h2>
          <p class="profile-bio reveal d2">Senior Software Engineer con 6+ años especializándome en performance testing y quality engineering. Actualmente en Wizeline como Performance Test Engineer con JMeter, liderando iniciativas de performance para aplicaciones de alta escala.</p>
          <div class="profile-roles reveal d3">
            <div class="role-chip">
              <div class="role-dot" style="background:#0071e3;"></div>
              <div>
                <div class="role-name">Ingeniero de performance</div>
                <div class="role-desc">Pruebas de carga y estrés con JMeter — Wizeline 2025–actualidad</div>
              </div>
            </div>
            <div class="role-chip">
              <div class="role-dot" style="background:#7c3aed;"></div>
              <div>
                <div class="role-name">Especialista en automatización mobile</div>
                <div class="role-desc">iOS & Android con Appium, XCUITest & Espresso</div>
              </div>
            </div>
            <div class="role-chip">
              <div class="role-dot" style="background:#1d8348;"></div>
              <div>
                <div class="role-name">Promotor de calidad</div>
                <div class="role-desc">Champion de buenas prácticas en equipos multidisciplinarios</div>
              </div>
            </div>
          </div>
          <div class="skills-group reveal">
            <div class="skills-label">Testing mobile</div>
            <div class="skills-chips">
              <span class="skill-chip">Appium</span><span class="skill-chip">XCUITest</span><span class="skill-chip">Espresso</span><span class="skill-chip">Appium Inspector</span>
            </div>
          </div>
          <div class="skills-group reveal d1">
            <div class="skills-label">Web y automatización</div>
            <div class="skills-chips">
              <span class="skill-chip">Playwright</span><span class="skill-chip">Cypress</span><span class="skill-chip">Selenium</span><span class="skill-chip">Nightwatch</span>
            </div>
          </div>
          <div class="skills-group reveal d2">
            <div class="skills-label">Performance y CI/CD</div>
            <div class="skills-chips">
              <span class="skill-chip">JMeter</span><span class="skill-chip">k6</span><span class="skill-chip">GitHub Actions</span><span class="skill-chip">Jenkins</span><span class="skill-chip">Grafana</span>
            </div>
          </div>
          <div style="margin-top:28px;" class="reveal d3">
            <a href="/Carlos_Cervantes_CV.pdf" class="button button-primary" target="_blank">Descargar CV</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="experience-section">
    <div class="section-wrap">
      <div class="section-header">
        <span class="s-eyebrow reveal">Experiencia</span>
        <h2 class="s-title reveal d1">Trayectoria profesional.</h2>
      </div>
      <div class="timeline">
        <div class="tl-item reveal">
          <div class="tl-period">2025 – Actualidad</div>
          <div class="tl-role">Senior Software Engineer — Performance Test Engineer</div>
          <div class="tl-company">Wizeline</div>
          <p class="tl-desc">Diseño y ejecución de estrategias de performance testing para garantizar escalabilidad y confiabilidad. Load, stress y endurance tests con análisis de bottlenecks e integración continua en CI/CD.</p>
          <div class="tl-tags"><span class="tl-tag">JMeter</span><span class="tl-tag">Performance Testing</span><span class="tl-tag">CI/CD</span><span class="tl-tag">Scalability</span></div>
        </div>
        <div class="tl-item reveal">
          <div class="tl-period">2024 – 2025</div>
          <div class="tl-role">Software QA Engineer III — Mobile Automation</div>
          <div class="tl-company">Wizeline</div>
          <p class="tl-desc">Lideré QA para aplicaciones móviles de real estate en iOS y Android con 10M+ usuarios. QA sign-off para features de IA, Feature Flag management y reducción de tiempo de regresión en 60%.</p>
          <div class="tl-tags"><span class="tl-tag">Appium</span><span class="tl-tag">XCUITest</span><span class="tl-tag">Espresso</span><span class="tl-tag">Feature Flags</span></div>
        </div>
        <div class="tl-item reveal">
          <div class="tl-period">2021 – 2024</div>
          <div class="tl-role">Software QA Engineer — Automation Engineer</div>
          <div class="tl-company">Wizeline</div>
          <p class="tl-desc">Automatización mobile y web para streaming SDK, e-commerce y apps móviles. Setup de infrastructure con GitHub Actions y Firebase Data Validation.</p>
          <div class="tl-tags"><span class="tl-tag">Cypress</span><span class="tl-tag">Selenium</span><span class="tl-tag">GitHub Actions</span><span class="tl-tag">Firebase</span></div>
        </div>
        <div class="tl-item reveal">
          <div class="tl-period">2019 – 2021</div>
          <div class="tl-role">Software Test Specialist / Intern → Engineer</div>
          <div class="tl-company">IBM</div>
          <p class="tl-desc">Arquitecté test plans completos y automation frameworks para aplicaciones Angular. UI testing con Nightwatch, performance con k6 y API testing con Postman en flujo Agile.</p>
          <div class="tl-tags"><span class="tl-tag">Nightwatch</span><span class="tl-tag">k6</span><span class="tl-tag">Grafana</span><span class="tl-tag">Postman</span></div>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
