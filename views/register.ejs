<%- include('partials/header') %>

<main class="page-shell auth-shell">
  <section class="section">
    <div class="shell-center">
      <div class="auth-card glass-card reveal">
        <span class="section-eyebrow">Registro</span>
        <h1 class="auth-title">Crea tu cuenta.</h1>
        <p class="muted-copy">Regístrate para comentar en el blog, guardar tu sesión y acceder a un panel personal dentro de la plataforma.</p>

        <% if (error) { %>
          <div class="auth-feedback auth-feedback-error"><i class="fas fa-circle-exclamation"></i><span><%= error %></span></div>
        <% } %>

        <form action="/register" method="POST" class="editor-layout auth-form">
          <div class="field">
            <label for="name">Nombre completo</label>
            <input id="name" name="name" type="text" class="text-input" placeholder="Carlos Cervantes" value="<%= formData?.name || '' %>" required>
          </div>
          <div class="field">
            <label for="email">Correo</label>
            <input id="email" name="email" type="email" class="text-input" placeholder="you@example.com" value="<%= formData?.email || '' %>" required>
          </div>
          <div class="form-grid auth-password-grid">
            <div class="field">
            <label for="password">Contraseña</label>
            <input id="password" name="password" type="password" class="text-input" minlength="8" placeholder="Mínimo 8 caracteres" required>
            </div>
            <div class="field">
              <label for="confirmPassword">Confirmar contraseña</label>
              <input id="confirmPassword" name="confirmPassword" type="password" class="text-input" minlength="8" placeholder="Repite tu contraseña" required>
            </div>
          </div>
          <div class="auth-actions">
            <button type="submit" class="button button-primary">Crear cuenta</button>
            <a href="/login" class="button button-ghost">Ya tengo cuenta</a>
          </div>
        </form>

        <p class="muted-copy auth-footnote">¿Ya tienes cuenta? <a href="/login">Inicia sesión aquí</a>.</p>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
