<%- include('partials/header') %>

<main class="main-content">
  
  <!-- Unified Header -->
  <section class="content-page-hero">
    <div class="container">
      <div class="hero-badge">
        <i class="fas fa-code-branch"></i>
        <span>Engineering & Automation</span>
      </div>
      <h1 class="hero-title-large">Strategic Projects</h1>
      <p class="hero-subtitle-refined">
        A collection of performance-driven QA frameworks and open-source contributions optimized for high-scale environments.
      </p>
    </div>
  </section>

  <!-- Projects Grid -->
  <section class="projects-section">
    <div class="container">
      <div class="content-grid">
        <% projects.forEach((project, index) => { %>
          <a href="<%= project.url %>" class="unified-card" target="_blank" rel="noopener noreferrer" style="animation-delay: <%= index * 0.1 %>s;">
            <div class="card-icon-container">
              <i class="fas fa-cube"></i>
            </div>
            
            <div class="card-tag-wrapper">
              <% if (project.language) { %>
                <span class="card-tag"><%= project.language %></span>
              <% } %>
            </div>
            
            <h3 class="card-title-refined"><%= project.name %></h3>
            
            <p class="card-desc-refined">
              <%= project.description || 'Enterprise-grade automation project focused on performance and reliability.' %>
            </p>
            
            <div class="card-action-refined">
              View Repository <i class="fas fa-arrow-right"></i>
            </div>
          </a>
        <% }); %>
      </div>
    </div>
  </section>

</main>

<%- include('partials/footer') %>

<%
// Helper function to get language colors (similar to GitHub)
function getLanguageColor(language) {
  const colors = {
    'JavaScript': '#f1e05a',
    'Python': '#3572A5',
    'Java': '#b07219',
    'TypeScript': '#2b7489',
    'Go': '#00ADD8',
    'Ruby': '#701516',
    'PHP': '#4F5D95',
    'C++': '#f34b7d',
    'C': '#555555',
    'Shell': '#89e051',
    'Dart': '#00B4AB',
    'Rust': '#dea584',
    'Swift': '#ffac45',
    'Kotlin': '#F18E33'
  };
  return colors[language] || '#ccc';
}
%>
