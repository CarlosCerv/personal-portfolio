<%- include('partials/header') %>

<%
  const totalPosts = posts.length;
  const publishedPosts = posts.filter(post => post.published !== false).length;
  const draftPosts = totalPosts - publishedPosts;
  const uniqueTags = [...new Set(posts.flatMap(post => post.tags || []).filter(Boolean))];
%>

<main class="page-shell admin-shell">
  <section class="section">
    <div class="admin-workspace reveal">
      <div class="admin-overview-card admin-card">
        <div class="admin-toolbar admin-toolbar-top">
          <div class="admin-intro">
            <span class="section-eyebrow">Panel editorial</span>
            <h1 class="admin-title">Gestiona el blog con una vista más clara y profesional.</h1>
            <p class="muted-copy">Revisa el estado del contenido, entra directo al editor y mantén el blog alineado con el diseño actual del sitio.</p>
            <div class="admin-switcher">
              <a href="/admin/posts" class="chip active">Posts</a>
              <a href="/admin/hobbies" class="chip">Intereses</a>
            </div>
          </div>
          <div class="toolbar-actions admin-hero-actions">
            <a href="/admin/logout" class="button button-ghost">Cerrar sesión</a>
            <a href="/admin/posts/new" class="button button-primary">Crear nuevo post</a>
          </div>
        </div>

        <div class="admin-stats-grid">
          <article class="admin-stat-card">
            <span class="admin-stat-label">Posts totales</span>
            <strong><%= totalPosts %></strong>
            <p>Contenido disponible en el panel editorial.</p>
          </article>
          <article class="admin-stat-card">
            <span class="admin-stat-label">Publicados</span>
            <strong><%= publishedPosts %></strong>
            <p>Artículos listos para leerse en el sitio.</p>
          </article>
          <article class="admin-stat-card">
            <span class="admin-stat-label">Borradores</span>
            <strong><%= draftPosts %></strong>
            <p>Piezas que todavía necesitan revisión o cierre.</p>
          </article>
          <article class="admin-stat-card">
            <span class="admin-stat-label">Etiquetas</span>
            <strong><%= uniqueTags.length %></strong>
            <p>Temas que ayudan a organizar la navegación del blog.</p>
          </article>
        </div>
      </div>

      <% if (posts.length > 0) { %>
        <div class="admin-collection-grid">
          <% posts.forEach(post => { %>
            <article class="admin-post-card admin-card reveal">
              <div class="admin-post-card-top">
                <div class="admin-post-copy">
                  <div class="admin-post-meta">
                    <span class="status-chip <%= post.published !== false ? 'success' : '' %>">
                      <%= post.published !== false ? 'Publicado' : 'Borrador' %>
                    </span>
                    <span class="admin-meta-slug">/<%= post.slug %></span>
                  </div>
                  <h2><%= post.title %></h2>
                  <p><%= post.metaDescription || 'Añade una meta descripción para mejorar la vista previa al compartir el artículo.' %></p>
                </div>
                <div class="admin-post-date">
                  <span class="admin-stat-label">Fecha</span>
                  <strong><%= new Date(post.date).toLocaleDateString('es-MX', { year: 'numeric', month: 'short', day: 'numeric' }) %></strong>
                </div>
              </div>

              <div class="admin-post-tags">
                <% if ((post.tags || []).length > 0) { %>
                  <% (post.tags || []).forEach(tag => { %>
                    <span class="tag"><%= tag %></span>
                  <% }) %>
                <% } else { %>
                  <span class="tag warning">Sin tags</span>
                <% } %>
              </div>

              <div class="admin-post-actions">
                <a href="/blog/<%= post.slug %>" target="_blank" rel="noreferrer" class="button button-ghost">Ver post</a>
                <a href="/admin/posts/edit/<%= post.slug %>" class="button button-ghost">Editar</a>
                <button type="button" class="button button-dark" onclick="deletePost('<%= post.slug %>')">Eliminar</button>
              </div>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state-card admin-empty-state">
          <p class="section-eyebrow">Estado vacío</p>
          <h2>Aún no hay publicaciones creadas.</h2>
          <p>Empieza con un nuevo artículo y usa el editor renovado para publicar con mejor estructura, metadata y vista previa.</p>
          <div class="hero-actions compact" style="justify-content:center;">
            <a href="/admin/posts/new" class="button button-primary">Crear primer post</a>
          </div>
        </div>
      <% } %>
    </div>
  </section>
</main>

<script>
  async function deletePost(slug) {
    if (!confirm('¿Seguro que quieres eliminar este post?')) return;

    try {
      const response = await fetch(`/api/admin/posts/${slug}`, { method: 'DELETE' });
      const data = await response.json();
      if (data.success) {
        window.location.reload();
        return;
      }
      alert(data.message || 'No fue posible eliminar el post.');
    } catch (error) {
      alert('Error al eliminar el post.');
      console.error(error);
    }
  }
</script>

<%- include('partials/footer') %>
