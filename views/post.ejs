<%- include('partials/header') %>
<%
  const likedByCurrentUser = !!(user && post.likes && post.likes.some(id => id.toString() === user._id.toString()));
%>

<main class="page-shell article-page">
  <section class="section">
    <article class="article-shell">
      <header class="article-header reveal">
        <span class="section-eyebrow">Insight técnico</span>
        <h1 class="article-title"><%= post.title %></h1>
        <p class="article-lead"><%= metaDescription %></p>
        <div class="article-meta">
          <span><%= post.author %></span>
          <span>•</span>
          <time datetime="<%= new Date(post.date).toISOString() %>"><%= new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></time>
          <span>•</span>
          <span><%= post.views %> views</span>
          <span>•</span>
          <span><%= post.commentCount %> comments</span>
        </div>
        <% if (post.tags && post.tags.length) { %>
          <div class="filter-bar">
            <% post.tags.forEach(tag => { %>
              <span class="tag"><%= tag %></span>
            <% }) %>
          </div>
        <% } %>
        <% if (post.coverImage) { %>
          <div class="article-cover">
            <img src="<%= post.coverImage %>" alt="<%= post.title %>">
          </div>
        <% } %>
      </header>

      <div class="article-body reveal">
        <%- post.htmlContent %>
      </div>

      <div class="content-card article-actions reveal">
        <div class="toolbar-actions">
          <button id="likeBtn" class="button <%= likedByCurrentUser ? 'button-dark' : 'button-ghost' %>" onclick="toggleLike()">
            <i class="<%= likedByCurrentUser ? 'fas' : 'far' %> fa-heart"></i>
            <span id="likeCount"><%= post.likes.length %></span>
          </button>
          <a href="#comments" class="button button-ghost"><i class="far fa-comment"></i><span><%= post.commentCount %></span></a>
          <button class="button button-ghost" onclick="copyPostLink()"><i class="fas fa-link"></i>Copiar enlace</button>
          <a href="/blog" class="button button-primary">Volver al blog</a>
        </div>
      </div>

      <section id="comments" class="content-card comments-shell reveal">
        <span class="section-eyebrow">Comunidad</span>
        <h3>Discusión</h3>
        <% if (user) { %>
          <form action="/posts/<%= post.slug %>/comment" method="POST" class="editor-layout" style="margin-top:18px;">
            <div class="field">
              <label for="commentContent">Comparte tu opinión</label>
              <textarea id="commentContent" name="content" class="text-area" placeholder="Agrega tu comentario" required></textarea>
            </div>
            <div class="toolbar-actions">
              <button type="submit" class="button button-primary">Publicar comentario</button>
            </div>
          </form>
        <% } else { %>
          <p class="muted-copy">Inicia sesión para dejar un comentario e interactuar con el artículo.</p>
          <div class="hero-actions compact">
            <a href="/login" class="button button-primary">Iniciar sesión</a>
            <a href="/register" class="button button-ghost">Crear cuenta</a>
          </div>
        <% } %>

        <div style="margin-top:18px;">
          <% if (comments && comments.length > 0) { %>
            <% comments.forEach(comment => { %>
              <div class="comment-card">
                <img src="<%= comment.user.profilePicture %>" alt="<%= comment.user.name %>" class="comment-avatar">
                <div>
                  <div class="post-meta">
                    <strong><%= comment.user.name %></strong>
                    <span>•</span>
                    <span><%= new Date(comment.createdAt).toLocaleDateString('en-US') %></span>
                  </div>
                  <p class="muted-copy" style="margin-top:8px;"><%= comment.content %></p>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <p class="muted-copy">Aún no hay comentarios. Sé el primero en iniciar la conversación.</p>
          <% } %>
        </div>
      </section>
    </article>
  </section>
</main>

<script>
  const postSlug = '<%= post.slug %>';
  const postUrl = '<%= metaUrl %>';

  window.addEventListener('load', () => {
    setTimeout(async () => {
      try {
        const response = await fetch(`/api/posts/${postSlug}/view`, { method: 'POST' });
        await response.json();
      } catch (error) {
        console.error('View tracking error:', error);
      }
    }, 2000);
  });

  async function toggleLike() {
    const btn = document.getElementById('likeBtn');
    try {
      const response = await fetch(`/api/posts/${postSlug}/like`, { method: 'POST' });
      if (response.status === 401) {
        window.location.href = '/login';
        return;
      }
      const data = await response.json();
      if (!data.success) return;

      btn.className = `button ${data.liked ? 'button-dark' : 'button-ghost'}`;
      btn.querySelector('i').className = `${data.liked ? 'fas' : 'far'} fa-heart`;
      document.getElementById('likeCount').textContent = data.likeCount;
    } catch (error) {
      console.error('Like error:', error);
    }
  }

  async function copyPostLink() {
    try {
      await navigator.clipboard.writeText(postUrl);
    } catch (error) {
      console.error('Copy link error:', error);
    }
  }
</script>

<%- include('partials/footer') %>
