{
  "name": "personal-website",
  "version": "1.0.0",
  "description": "Premium personal portfolio built with Next.js, TypeScript and Tailwind CSS",
  "scripts": {
    "dev": "PATH=\"/usr/local/bin:$PATH\" next dev",
    "build": "PATH=\"/usr/local/bin:$PATH\" next build",
    "start": "next start",
    "test": "jest --testEnvironment node --forceExit",
    "build:favicon": "node scripts/generate-ico.js",
    "deploy": "bash scripts/deploy-vercel.sh prod",
    "deploy:preview": "bash scripts/deploy-vercel.sh preview"
  },
  "jest": {
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 30000
  },
  "keywords": [
    "portfolio",
    "nextjs",
    "typescript",
    "tailwind",
    "qa",
    "performance"
  ],
  "author": "Carlos Cervantes",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "@tiptap/extension-code-block-lowlight": "^3.22.2",
    "@tiptap/extension-image": "^3.22.2",
    "@tiptap/extension-link": "^3.22.2",
    "@tiptap/extension-placeholder": "^3.22.2",
    "@tiptap/extension-table": "^3.22.2",
    "@tiptap/extension-table-cell": "^3.22.2",
    "@tiptap/extension-table-header": "^3.22.2",
    "@tiptap/extension-table-row": "^3.22.2",
    "@tiptap/react": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.7.0",
    "marked": "^9.1.6",
    "mongoose": "^8.19.2",
    "next": "^16.2.2",
    "pdfkit": "^0.18.0",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "resend": "^6.10.0",
    "sanitize-html": "^2.17.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
